# =============================================================================
# .env.example — Developer-specific path configuration for docker-compose.yml
#
# Copy this file to .env.<yourname> (e.g. .env.aaron, .env.claude)
# and adjust paths for your machine.
# These files are gitignored — each developer maintains their own copy.
#
# Usage — always pass --env-file so docker compose knows which config to use:
#
#   docker compose --env-file .env.aaron --profile unit-django run --rm unit-django-runner
#   docker compose --env-file .env.claude --profile integration run --rm integration-runner
#   docker compose --env-file .env.claude --profile e2e run --rm e2e-runner
#
# =============================================================================

# --- Absolute paths to project directories ---
# Windows (native docker compose): use forward slashes (C:/Users/...)
# Linux/WSL (native docker/podman):  use standard paths (/home/... or /app/...)

# Path to koalixcrm repository
KOALIXCRM_DIR=../koalixcrm

# Path to directory containing db/ subfolder and secrets.env
# Must contain secrets.env (copy docker/secrets.env.example there and fill in real secrets)
KOALIXCRM_DB_DIR=../koalixcrm_data

# Path to this system repository (where this file lives)
KOALIXCRM_SYSTEM_DIR=.

# -----------------------------------------------------------------------------
# OPTIONAL: daemon-side overrides
# -----------------------------------------------------------------------------
# Set these ONLY if your shell and Docker daemon see different filesystem paths.
# Typical case: WSL shell talking to Docker Desktop on Windows — the WSL shell
# sees /app/... while the Windows docker daemon only sees C:/Users/...
#
# On native Windows/macOS/Linux, leave these commented out — the *_DIR values
# above are used for both parse-time and runtime.
#
# Example (Claude Code in WSL + Docker Desktop on Windows):
#   KOALIXCRM_HOST_DIR=//c/Users/aaron/koalixcrm
#   KOALIXCRM_DB_HOST_DIR=//c/Users/aaron/koalixcrm_data
#   KOALIXCRM_SYSTEM_HOST_DIR=//c/Users/aaron/koalixcrm_system

# KOALIXCRM_HOST_DIR=
# KOALIXCRM_DB_HOST_DIR=
# KOALIXCRM_SYSTEM_HOST_DIR=

# --- Django auto-reload ---
# Set to 1 to enable Django's StatReloader for live code reloading (dev profile).
# Default is 0 (--noreload) which prevents spurious restarts on volume-mounted
# filesystems (WSL2, Docker Desktop). Only useful with the dev profile.
# DJANGO_AUTORELOAD=1

# --- Optional port overrides ---
# DJANGO_PORT=8000
# MINIO_API_PORT=9010
# MINIO_CONSOLE_PORT=9011
# ELASTICMQ_PORT=9324
# ELASTICMQ_UI_PORT=9325
# NGINX_PORT=5000
# ALLURE_PORT=5001
