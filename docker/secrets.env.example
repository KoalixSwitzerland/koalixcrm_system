# =============================================================================
# secrets.env — All secrets consumed by the KoalixCRM stack
#
# Copy this file to ${KOALIXCRM_DB_DIR}/secrets.env and fill in the real values.
# This file is the ONLY place where secrets live — everything else in
# docker-compose.yml is inlined for visibility.
#
# Loaded via `env_file:` into these services:
#   - backend            (Django): OIDC (if cloud) + API keys
#   - celery             (Celery): OIDC (if cloud) + API keys
#   - integration-runner (pytest): same as backend
#   - e2e-runner         (pytest): same as backend
#
# NOTE: Keycloak is NOT used locally (internal/external URL mismatch would
# require safety-critical auth code changes). These OIDC vars are only needed
# if you connect to a cloud-hosted Keycloak realm for testing.
# =============================================================================

# ----- OIDC (optional — only for cloud Keycloak testing) -----
# OIDC_ISSUER=https://auth.example.com/realms/koalixcrm
# OIDC_ACCEPTED_AUDIENCES=koalixcrm-frontend

# ----- E2E test-user credentials -----
# Django admin superuser created via: python manage.py createsuperuser
E2E_ADMIN_USERNAME=admin
E2E_ADMIN_PASSWORD=admin

# ----- Third-party API keys (if needed by microservices) -----
# OPENAI_API_KEY=CHANGE_ME
