# =============================================================================
# secrets.env — All secrets consumed by the KoalixCRM stack
#
# Copy this file to ${KOALIXCRM_DB_DIR}/secrets.env and fill in the real values.
# This file is the ONLY place where secrets live; everything else in
# docker-compose.yml is inlined for visibility.
#
# Loaded via `env_file:` into these services:
#   - backend            (Django): OIDC admin login + API token validation
#   - celery             (Celery): M2M OIDC token for API calls
#   - integration-runner (pytest): same as backend
#   - e2e-runner         (pytest): same as backend
# =============================================================================

# ----- Admin OIDC client (Django admin login via cloud Keycloak) -----
ADMIN_OIDC_ISSUER=CHANGE_ME
ADMIN_OIDC_CLIENT_ID=CHANGE_ME
ADMIN_OIDC_CLIENT_SECRET=CHANGE_ME

# ----- Shared OIDC validation (API accepts Bearer tokens) -----
OIDC_ISSUER=CHANGE_ME
OIDC_ACCEPTED_AUDIENCES=CHANGE_ME

# ----- M2M client (Celery worker — client_credentials grant) -----
CELERY_WORKER_M2M_OIDC_ISSUER=CHANGE_ME
CELERY_WORKER_M2M_CLIENT_ID=CHANGE_ME
CELERY_WORKER_M2M_CLIENT_SECRET=CHANGE_ME
CELERY_WORKER_M2M_SCOPE=CHANGE_ME

# ----- E2E test-user credentials -----
E2E_ADMIN_USERNAME=admin
E2E_ADMIN_PASSWORD=admin
